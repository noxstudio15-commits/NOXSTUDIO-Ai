<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>NOXSTUDIO AI</title>
<style>
body { font-family: Arial; background: #f5f5f5; margin:0; padding:0; }
#splash { position: fixed; width: 100%; height: 100%; background: #000; color: #fff; display:flex; justify-content:center; align-items:center; font-size:24px; }
#app { display:none; padding:20px; max-width:600px; margin:auto; }
#output { white-space: pre-wrap; background:#fff; padding:10px; margin-top:10px; border:1px solid #ccc; height:200px; overflow-y:auto; }
input, button { padding:10px; margin-top:5px; width:100%; box-sizing:border-box; }
#warning { position: fixed; bottom: 10px; right: 10px; color:red; }
</style>
</head>
<body>

<!-- شاشة البداية -->
<div id="splash">اهلا فيك في AI NOXSTUDIO 🤖</div>

<!-- التطبيق -->
<div id="app">
<h2>NOX AI 🤖</h2>
<input id="input" placeholder="اكتب هنا...">
<button onclick="sendMessage()">ارسال</button>
<pre id="output">الدردشة ستظهر هنا...</pre>
<div id="warning">⚠️ انتبه لا ترسل شي مخالف والا حظر نهائي</div>
</div>

<script>
let bannedWords = ["اختراق","ممنوع","hack"];
let chats = [];

function getLang() {
  let lang = navigator.language;
  return lang.includes("ar") ? "ar" : "en";
}

// شاشة الترحيب 7 ثواني
setTimeout(() => {
  document.getElementById("splash").style.display = "none";
  document.getElementById("app").style.display = "block";
},7000);

async function sendMessage() {
  let input = document.getElementById("input").value.trim();
  let output = document.getElementById("output");
  if(!input) return;

  // تحقق من كلمات محظورة
  if(bannedWords.some(word => input.includes(word))) {
    alert("تم حظر حسابك نهائيًا ❌");
    localStorage.setItem("banned", true);
    return;
  }

  // حفظ الدردشة مؤقتًا
  let title = input.slice(0,20);
  chats.push({title: title, message: input});

  output.innerText += "\n\nأنت: " + input + "\n";

  // الاتصال بالـ API (تحتاج مفتاح OpenAI)
  let res = await fetch("https://api.openai.com/v1/chat/completions", {
    method: "POST",
    headers: {
      "Authorization": "Bearer YOUR_API_KEY",
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      model: "gpt-4o-mini",
      messages: [
        {role:"system", content:"انت ذكاء اصطناعي عربي يجاوب على أي سؤال، ويكتب سكربتات Lua للروبلوكس اذا طلب."},
        {role:"user", content: input}
      ],
      max_tokens:300
    })
  });
  let data = await res.json();
  let reply = data.choices[0].message.content;
  output.innerText += "AI: " + reply;
  output.scrollTop = output.scrollHeight;
  document.getElementById("input").value = "";
}

// تحقق من الحظر عند فتح الصفحة
if(localStorage.getItem("banned")) {
  alert("تم حظر حسابك نهائيًا ❌");
  document.getElementById("app").style.display = "none";
}
</script>

</body>
</html>
